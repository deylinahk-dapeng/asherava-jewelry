# Copy to deploy.env (same folder) and fill in. deploy.env is gitignored.
#
# SpinUpWP typical paths:
#   REMOTE_THEME_DIR=/sites/asherava.com/files/wp-content/themes/asherava-jaxxon
#
# Use SSH config alias (recommended): Host asherava in ~/.ssh/config
SSH_HOST=asherava
REMOTE_THEME_DIR=/sites/asherava.com/files/wp-content/themes/asherava-jaxxon

# Optional: purge SpinUpWP / Nginx cache after deploy (requires wp-cli on server)
# PURGE_CACHE=1
